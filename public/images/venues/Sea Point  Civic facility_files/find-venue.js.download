    });

    // Checkin and Checkout date icon bindings
    $('#checkInDate').nextAll('span:first').click(function () {
        $("#checkInDate").focus();
    });

    $('#checkOutDate').nextAll('span:first').click(function () {
        $("#checkOutDate").focus();
    });

    // Hide from starting render
    $('#startDate, #endDate, #checkInDate, #checkOutDate').data("DateTimePicker").hide();
    $('#endDate').data("DateTimePicker").hide();

    $('#checkInDate').data("DateTimePicker").hide();
    $('#checkOutDate').data("DateTimePicker").hide();

   /* $("#startDate").on("dp.change", function (e) {
