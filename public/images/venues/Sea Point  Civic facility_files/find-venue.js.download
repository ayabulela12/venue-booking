	//Mobile Search Toggle
	$('#btnMobileSearch').click(function(){
		$('#searchTabContainer').toggle();
		$('#searchContainer').toggle();
		if($('#searchTabContainer').is(':visible')){
			$(this).addClass('active');
			$(this).find('i').addClass('fa-remove');
		}else{
			$(this).removeClass('active');
			$(this).find('i').removeClass('fa-remove');
		}
    });

    $(".find-header-row").prepend($(".mobile-search-btn-cnt"));
	
	//Search results Search and Filter Toggle
	$('#btnMobileSearchResult').click(function(){
		// alert('Test');
		$('#searchTabContainer').toggle();
        $('#searchResultContainer').toggle();
        $('#searchContainer').toggle();
		if($('#searchTabContainer').is(':visible')){
			$(this).addClass('active');
			$(this).find('i').addClass('fa-remove');
		}else{
			$(this).removeClass('active');
			$(this).find('i').removeClass('fa-remove');
		}
	});
	$('#btnMobileFilterResult').click(function(){
		 	
		if($('#filterContainer').hasClass('hide')){
			$(this).find('i').removeClass('fa-sliders');
			$(this).addClass('active');
			$(this).find('i').addClass('fa-remove');
			$('#filterContainer').removeClass('hide');
		}else{
			$(this).find('i').addClass('fa-sliders');
			$(this).removeClass('active');
			$(this).find('i').removeClass('fa-remove');
			$('#filterContainer').addClass('hide');
		}
	});
	
	//Page 1 tab click
	$('#btnHalls').click(function(){
		$('.tab-cnt .btn').removeClass('active');
