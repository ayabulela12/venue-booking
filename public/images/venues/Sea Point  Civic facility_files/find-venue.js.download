	//Filter button
    $("#filterBtn").addClass("filterBtn-color");
	$("#filterBtn").click(function(){
		if($("#filterContainer").hasClass("hide")){
			$(this).find('i').removeClass("fa-angle-down");
			$(this).find('i').addClass("fa-angle-up");
            $("#filterContainer").removeClass("hide");
            $("#filterBtn").removeClass("filterBtn-color");
		}else{
			$(this).find('i').addClass("fa-angle-down");
			$(this).find('i').removeClass("fa-angle-up");
            $("#filterContainer").addClass("hide");
            $("#filterBtn").addClass("filterBtn-color");
		}
	});



    $('select2-results__option').removeClass("select2-results__option--highlighted");

    //Esri Popup Wrapper
    /*$(document).mouseup(function (e) {
        var container = $(".esriPopup");

        if (!container.is(e.target) && container.has(e.target).length === 0) {

            container.fadeOut();

        }
    });*/

    $(document).mouseup(function (e) {
        //Map popup
        var container = $(".esriPopup");
        if ($(e.target).is("image")) {
            container.fadeIn();
        } else {
            if (!container.is(e.target) && container.has(e.target).length === 0) {
                container.fadeOut 
            }
        }

    }); 
});

}
