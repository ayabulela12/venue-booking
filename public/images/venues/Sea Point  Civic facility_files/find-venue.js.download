		placeholder: "Select an option",
        theme: "bootstrap",
        dropdownParent: $('#venueContainer > div:nth-child(1) > div:nth-child(2) > div')
	});

	$('#capacity').on("change", function(){
		CapacitySelected = $(this).val();
	   });
	
	
	//Start time
	function populate(selector) {
		var select = $(selector);
		var hours, minutes, ampm;
	   // for (var i = 0; i <= 1450; i += 60) {
		for (var i = 660; i <= 1390; i += 60) {
			hours = Math.floor(i / 60);
			minutes = i % 60;
			if (minutes < 10) {
				minutes = '0' + minutes; // adding leading zero to minutes portion
			}
			select.append($('<option></option>')
			.attr('value', hours)
			.text(hours + ':' + minutes));

		}
	}
	
	//End time
	function populate2(selector) {
		var select = $(selector);
		var hours, minutes, ampm;
	   // for (var i = 0; i <= 1450; i += 60) {
		for (var i = 0; i <= 1390; i += 60) {
			hours = Math.floor(i / 60);
			minutes = i % 60;
			if (minutes < 10) {
				minutes = '0' + minutes; // adding leading zero to minutes portion
			}
			//add the value to dropdownlist
			select.append($('<option></option>')
				.attr('value', hours)
				.text(hours + ':' + minutes));
		}
		console.log('Start time  populated set');
	}
	
	// populate('#startTime');
	// populate2('#endTime');
	
	$("#startTime").select2({
		minimumResultsForSearch: -1,
		placeholder: "Start time",
        theme: "bootstrap",
        dropdownParent: $('#venueContainer > div:nth-child(2) > div:nth-child(3) > div')
	});
	$("#endTime").select2({
		minimumResultsForSearch: -1,
