/*!
 Custom DataTable JS
*/

// Right now there are 3 variations for data tables - all 3 will be implemented inside this JS file for now.

$(document).ready(function () {
    // 1) Basic Data Table with dom elements and zero configuration:
    // var table = $('table.dtCustom').DataTable({
    $("table.dt-custom").DataTable({
        language: {
            searchPlaceholder: "Type here",
            //customize pagination prev and next buttons: use arrows instead of words
            paginate: {
                //'previous': '<span class="fa fa-chevron-left"></span>',
                //'next': '<span class="fa fa-chevron-right"></span>'
                previous: '<i class="sprite chevron-left-dark"></i>',
                next: '<i class="sprite chevron-right-dark"></i>',
            },
        },

        sDom:
            "A<'row search-entries'<'col'l f>>" +
            "<'row'<'col-12'<'datatable-pagination'i<'tab-dom'p>>>>" +
            "<'row'<'col-sm-12'tr>>" +
            "<'row'<'col-12'<'datatable-pagination'i<'tab-dom'p>>>>",

        alphabetSearch: {
            column: 0,
        },

        alphabetSearch: {
            column: 1,
        },

        drawCallback: function () {
            $(".alphabet ul").addClass("pagination flex-wrap knowledge-hub");
            $(".alphabet li").addClass("page-item");
            $(".alphabet li a").addClass("page-link");

            $(".alphabet .alphabet-info-display").addClass("form-control-static");
            $(".alphabet a.active").closest("li").addClass("selected");

            $(".alphabet li.page-item a.page-link").click(function () {
                // If the clicked element has the active class, remove the active class from EVERY .nav-link>.state element
                if ($(this).hasClass("active")) {
                    $("a.page-link").removeClass("active");
                    $(this).parent().addClass("selected");
                }
                // Else, the element doesn't have the active class, so we remove it from every element before applying it to the element that was clicked
                else {
                    $("a.page-link").removeClass("active");
                    $(this).parent().removeClass("selected");
                    $(this).addClass("active");
                    $(this).parent().addClass("selected");
                }
            });

            // Modify alphabet filter
            $("li.page-item").has("a.empty").addClass("disabled");

            //A-Z Filter - Reposition - bottom
            // $(".alphabet-bottom").html($(".alphabet"));

            //Scroll to data table when search button click or keypress
            $(".dt-custom-top input").keyup(function (event) {
                if (event.which === 13) {
                    $("#dt-custom-search").click();
                }
            });

            $("#dt-custom-search").click(function () {
                $('html, body').animate({
                    scrollTop: $(".dt-custom").parent().parent().parent().offset().top
                }, 2000);
            });
        },
    });

    //Reposition search box as per design
    $("#dt-custom-top").html($(".dataTables_filter input"));
    $("#dt-custom-top input:nth-child(2)").appendTo($("#dt-custom-bottom"));

    //Add class to search box
    $(".dt-search div.search-block input").addClass("search-focus");
    $(".dt-search div.search-block input").removeClass("form-control-sm");


    //A-Z Filter - Reposition - bottom (does not work with onclick)
    //$(".alphabet").clone().appendTo(".alphabet-bottom");

    //2) Basic Data Table with zero dom elements:

    // Get Data
    /*var testDataUrl = "assets/js/tableData.json";


    $("#loadData").click(function () {
        loadData();
    });

    function loadData() {
        $.ajax({
            type: 'GET',
