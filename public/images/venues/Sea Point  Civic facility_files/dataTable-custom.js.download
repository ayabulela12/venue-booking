    var complexDataTable = $("table.dt-complex").DataTable();
    if (complexDataTable != "undefined") {
        complexDataTable.destroy();
    }

    complexDataTable = $("table.dt-complex").DataTable({
        aaData: data,

        language: {
            searchPlaceholder: "Type here",
            //customize pagination prev and next buttons: use arrows instead of words
            paginate: {
                //'previous': '<span class="fa fa-chevron-left"></span>',
                //'next': '<span class="fa fa-chevron-right"></span>'
                previous: '<img src="assets/images/arrow-left.png">',
                next: '<img src="assets/images/arrow-right.png">',
            },
        },

        // Output all columns/ HTML - $.fn.dataTable.Responsive.renderer.tableAll
        responsive: {
            details: {
                display: $.fn.dataTable.Responsive.display.modal({
                    header: function (row) {
                        var data = row.data();
                        //console.log(data.title);
                        return "Details for " + data.title + " " + data.first_names + " " + data.surname;
                    },
                }),
                renderer: $.fn.dataTable.Responsive.renderer.tableAll({
                    tableClass: "table",
                }),
            },
        },

        sDom:
            "<'row'<'col-sm-3'l><'col-sm-3'f>>" +
            "<'col-12 mb-3 pl-xl-0 pl-lg-0 pl-md-0 pl-sm-0 pr-xl-0 pr-lg-0 pr-md-0 pr-sm-0'<'results-pagination d-flex align-items-center'i<'tab-dom'p>>>" +
            "<'row'<'col-sm-12'tr>>" +
            "<'col-12 mb-3 mt-3 pl-xl-0 pl-lg-0 pl-md-0 pl-sm-0 pr-xl-0 pr-lg-0 pr-md-0 pr-sm-0'<'results-pagination d-flex align-items-center'i<'tab-dom'p>>>" +
            "<'row'<'col-sm-3'f>>",

        aoColumns: [
            {
                mData: "title",
            },
            {
                mData: "first_names",
            },
            {
                mData: "surname",
            },
            {
                mData: "designation",
            },
            {
