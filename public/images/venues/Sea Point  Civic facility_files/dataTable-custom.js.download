                department.sub_department,
                department.contact_number,
                department.fax_number,
                department.email
            ]);
        }
    }*/

    var jsonData = [
        { sub_department: "EPWP Help Desk", contact_number: "+27(0) 123 4567", fax_number: "+27(0) 123 4567", email: "ashley.heynes@capetown.gov.za" },
        { sub_department: "Facilities Management Help Desk", contact_number: "+27(0) 123 4567", fax_number: "+27(0) 123 4567", email: "ashley.heynes@capetown.gov.za" },
        { sub_department: "HR Service Desk (Option 1)(Roll-over style)", contact_number: "+27(0) 123 4567", fax_number: "+27(0) 123 4567", email: "ashley.heynes@capetown.gov.za" },
    ];

    $("table.dt-basic").DataTable({
        data: jsonData,
        columns: [
            { data: "sub_department" },
            { data: "contact_number" },
            { data: "fax_number" },
            //{ data: 'email' }
            {
                data: "email",
                render: function (data, type, row, meta) {
                    if (type === "display") {
                        data = '<a href="mailto:' + data + '">' + " Email " + "</a>";
                    }

                    return data;
                },
            },
        ],
        //Display on the table - no dom elements
        sDom: "<'row'<'col-sm-12'tr>>",

        columnDefs: [
            {
                targets: -1, // Start with the last
                render: function (data, type, row, meta) {
                    if (type === "display") {
                        data = '<a href="profile.php?id=' + encodeURIComponent(data) + '">View Profile</a>';
                    }
                    return data;
                },
            },
        ],
    });

    //3) Complex Data Table with dom elements:

    var data = [
        {
