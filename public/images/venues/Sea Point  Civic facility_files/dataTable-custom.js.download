                mData: "building",
            },
            {
                mData: "building_street_address",
            },
            {
                mData: "floor",
            },
            {
                title: "Print Information",
                sClass: "col-sm-2",
                render: function (data, type, row) {
                    return '<button type="button" onclick="window.print()" id="dt-print" class="btn btn-dark btn-small" data-toggle="tooltip" data-placement="bottom" title="" data-original-title="Print this page"><img class="options_icon" src="assets/images/ic_local_printshop_48px.svg" alt="Print">Print</button>';
                },
            },
        ],

        drawCallback: function () {},
    });

    //Print function
    $(document).on("click", "#print", function () {
        var section = $("body");
        var modalBody = $(".modal-body").detach();

        var content = $(".s4-workspace").detach();
        section.append(modalBody);
        window.print();
        section.empty();
        section.append(content);
        $(".modal-content").append(modalBody);
    });

    //Reposition search box as per design
    $("#dt-complex-top").html($(".dataTables_filter input"));
    $("#dt-complex-top input:nth-child(2)").appendTo($("#dt-complex-bottom"));

