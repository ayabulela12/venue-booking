function setFeaturesClick() {
$('.ms-ref-refinername').on('click', function (e) {
    if ($(this).hasClass("closed")) {
        // var allPanels = $('.ms-ref-refiner > div > div > div > fieldset.ms-ref-unselSec').show();

        $(".ms-ref-refinername").each(function () {

            closeFilterTab($(this));
        });

        openFilterTab($(this));
    }
    else if ($(this).hasClass("open")) {
        
        closeFilterTab($(this));
    }
});



}

function clearAllFeaturesSelected() {

    $("#FacilityFeatures-MultiRefiner").find(':checkbox').each(function(){
        $(this).prop('checked', '');
    });


         //Filter button
         $("#filterBtn").click(function(){
            if($("#filterContainer").hasClass("hide")){
                $(this).find('i').removeClass("fa-angle-down");
                $(this).find('i').addClass("fa-angle-up");
                $("#filterContainer").removeClass("hide");
            }else{
                $(this).find('i').addClass("fa-angle-down");
                $(this).find('i').removeClass("fa-angle-up");
                $("#filterContainer").addClass("hide");
            }
        });

        $("#advancedClearBtn").hide();
        setTimeout(() => {
            location.href = location.href.split("&refiners=")[0];
        }, 500);
        
        
}




var fs = [];

var theDatatable = null;

var facilityNames = "";
var facilityNamesArray = [];
var facilityPhotosArray = [];
var facilityLocation = [];
var facilityType = "";


var theFacilityData = null;
var refinerCollection = [];

function setFacilityTable(facilityDataJson) {
    theFacilityData = JSON.parse(facilityDataJson);
   counter = 1;



   theDatatable = $("table.foundFacilities").DataTable({
        data: theFacilityData,
        pageLength: 50,
        deferRender: true,
        columns: [
            { 
            targets: 0,
            render: function (data, type, row, meta) {
                    counter = meta.row - (Math.floor(meta.row / 50) * 50) + 1;

                    var facilityTitleNoSpaces = '';

                    // row.Name = row.Name.replace(/’/g, '\'');
                    row.Name = row.Name.replace(/'/g, '\'');
                    facilityTitleNoSpaces = row.Name.replaceAll('’','');
                    facilityTitleNoSpaces = facilityTitleNoSpaces.replaceAll('\'','');
                    facilityTitleNoSpaces = facilityTitleNoSpaces.replace(/\s/g, '');
                    facilityTitleNoSpaces = facilityTitleNoSpaces.replace(/-/g, '');
                    facilityTitleNoSpaces = facilityTitleNoSpaces.replaceAll("-" , "");
                    facilityTitleNoSpaces = facilityTitleNoSpaces.replaceAll("/" , "");
                    facilityTitleNoSpaces = facilityTitleNoSpaces.replace(":" , "");
                    facilityTitleNoSpaces = facilityTitleNoSpaces.replaceAll("'" , "");

                    var result = "<div class='row m-b-20 search-item list-figure-item'><figure><a href='facility?facilitytype=" + row.FacilityType + '&facilityname=' + row.Name + "' title='" + row.Name + "'>";
                    result += "<img src='" + row.RollupImage + "' alt='' class='responsive'/></a></figure><h4>";
                    result += "<img src='assets/images/FacilityBookingPins/pin" + counter + ".png' class='icon map-pin' alt='" + row.Name  + "'>";
                    result += " <a href='facility?facilitytype=" + row.FacilityType + '&facilityname=' + row.Name.replaceAll("'","%27") + "' title='" + row.Name.replaceAll("'","%27") +"' title=''>" + row.Name + "</a>";
                    result += "<a href='#' onclick='fs[&quot;" + facilityTitleNoSpaces + "&quot;]();   return false; ' title='Check Availability' id='CA-btn-top' class='btn right' style=''>Check Availability</a></h4>";
                    result += " <div class='col-7'><p class='sml locAlign'>" + row.Location + "</p></div>";
                    result += "<p id='ContactDetails" + facilityTitleNoSpaces  + "' class='col-7 sml contactAlign' style='display:none;'> " + row.Location +  "<br><a href='tel:" + row.BookingClerkContactPhone + "'>" + row.BookingClerkContactPhone + "</a><br><a href='mailto:RPHall.Bookings@capetown.gov.za'>RPHall.Bookings@capetown.gov.za</a></p> <a href='#' onclick='fs[&quot;" + facilityTitleNoSpaces + "&quot;]();  return false; ' title='Check Availability' id='CA-btn-bottom' class='btn right' style=' '>Check Availability</a></div>";
                    // result += "<div style='display:none;'>" + row.Features +   "</div>";

                     try {
                        var el = document.createElement( 'div' );
                        el.innerHTML = row.CalendarData;
             
                        var showCheckAvailability = ""
             
                        var calendarData2 = el.getElementsByTagName( 'script' );
                        if (calendarData2.length > 0)
                        {
                            fs[facilityTitleNoSpaces] = new Function('show' + facilityTitleNoSpaces + 'Calendar', calendarData2[0].innerText.replace('//]]>',';').replace('\n','').replaceAll("SingleQuote","\'") + ' showListingCalendar(resources,events,"' + row.Name + '"); ');
                        }
                    } catch(error)
                    {
                    showCheckAvailability = "display:none;"
                    console.log("Error: " + row.Name + ":  " + error);
                    }
                    facilityNamesArray[meta.row] = row.Name;
                    facilityPhotosArray[meta.row] = row.RollupImage;
                    facilityLocation[meta.row] = row.Location;
                    facilityType = row.FacilityType
                    counter = counter + 1 
                   

                    
                    return  result;

            },
         },  
         { 
            targets: 1,

            render: function (data, type, row, meta) {

                var result2 = '';
                
                row.Features.forEach(element => {
                    result2 += element + ",";
                });

                

                return "<div style='display:none;'>" + result2 + "</div>";


            },
         },    
        ],
        "drawCallback": function( settings ) {
            $("table.foundFacilities thead").remove();
        },
        language: {
            paginate: {
                previous: '<i class="sprite chevron-left-dark"></i>',
                next: '<i class="sprite chevron-right-dark"></i>',
            },
        },
        // pagingType: "scrolling",
        sDom:
            "<'row'<'col-12'<'datatable-pagination'i<'tab-dom'p>>>>",
    });
    counter = 1;
    
    setFacilityNames();

    $("table.foundFacilities").on( 'page.dt', function () {
        facilityNames = "";
        setFacilityNames();
    } );
    
  }


  function setRefiners() {
    var existingRefiners = '';
    if (location.href.split("&refiners=")[1] != undefined) {
     existingRefiners = location.href.split("&refiners=")[1];
    }


 
    if (existingRefiners != '') {

        refinerCollection = existingRefiners.split(',');
    }

    refinerCollection.forEach(function(currentValue, index) {


        refinerCollection[index] = decodeURI(currentValue);
    });


    $("#FacilityFeatures-MultiRefiner").find(':checkbox').each(function(){


        if (refinerCollection.includes($(this).val())) {

            $(this).prop('checked', 'checked');
            $("#advancedClearBtn").show();
        }
    });




  }

function refineSearch(featureName,checked) {


    var url = location.href.split("&refiners=")[0];
    var existingRefiners = '';
    if (location.href.split("&refiners=")[1] != undefined) {
       existingRefiners = location.href.split("&refiners=")[1];
    }
 
    if (checked) {
    refinerCollection.push(featureName);
    } else {
        const index = refinerCollection.indexOf(featureName);
        if (index > -1) { 
            refinerCollection.splice(index, 1);
        }
    }


    location.href = url + "&refiners=" + refinerCollection.toString();

}

 
