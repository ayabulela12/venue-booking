var TheFacilityTitle = '';

function setFacilityName(facilityName) {

    TheFacilityTitle = facilityName;
  
}

var resources = '';

function setResources(theresources) {

    resources = JSON.parse(theresources);
    
}


var events = '';

function setEvents(theevents) {

    events = JSON.parse(theevents);


}

function showCalendar()
{

    
    toggleModal();

    $('#calendar').attr("style", "");
    $('#divcaldatespan').html(TheFacilityTitle);


    if ($('#calendar')) {
        $('#calendar').fullCalendar('destroy'); // Destroy the calender and all resource/events.. Ready for next generation
    }
    // Define the full calender functionality , attributes
    // Start  -- Defining Full Calender
    $('#calendar').fullCalendar({

        schedulerLicenseKey: 'GPL-My-Project-Is-Open-Source',
        themeSystem: 'bootstrap4', // Select Theme system - base is standard or empty ,jquery-ui, bootstrap3
        editable: false, // enable draggable events
        nowIndicator: true,
        contentHeight: "auto",
        contentWidth: "auto",
        timezone: "Africa/Harare",
        firstDay: 1,
        navLinks: true,
        locale: "en-gb",
        businessHours: false,
        eventOverlap: false,
        slotDuration: '01:00:00',  // Set Time Slot (1 Hour default)
        //timeFormat: 'H(:mm)', // uppercase H for 24-hour clock
        allDayDefault: false,
        aspectRatio: 1.8, // 1.8 Default
        scrollTime: '08:00', // undo default 6am scrollTime
        displayEventTime: false,

        // Add your event
        selectable: false,
        selectOverlap: false,
        selectHelper: true,
        eventBorderColor: "black",

        eventClick: function (eventObj) {
            if (eventObj.url) {
                alert(
                    'Clicked ' + eventObj.title + '.\n' +
                    'Will open ' + eventObj.url + ' in a new tab'
                );

                window.open(eventObj.url);

                return false; // prevents browser from following link in current tab.
            } else {

                $('#calendar').fullCalendar('changeView', 'timelineDay', eventObj.start);
            }
        },

        // Monitor event drop and schedule change
        eventDrop: function (event, delta, revertFunc) {

            eventnewstart = moment(event.start).format("DD MMMM YYYY");
            eventnewend = moment(event.end).format("DD MMMM YYYY");
            eventnewstarttime = moment(event.start).format("HH");
            eventnewendtime = moment(event.end).format("HH");

            if (!confirm("Confirm new date: " + eventnewstart + " " + eventnewstarttime + "h00 - " + eventnewend + " " + eventnewendtime + "h00")) {
                revertFunc();
            } else {
                // write new selection date

                document.getElementById("divcaldatespan").innerHTML = "<h3>DATE SELECTION: " + eventnewstart + " - " + eventnewend + "</h3>";
                eventnewstarttime = moment(event.start).format("HH:MM");
                eventnewendtime = moment(event.end).format("HH:MM");
                eventnewstart = moment(event.start).format("DD/MM/YYYY");
                eventnewend = moment(event.end).format("DD/MM/YYYY");

            }

        },

        // Monitor event resize and schedule change
        eventResizeStop: function (event, delta, revertFunc) {

            //alert(event.title + " was resized on " + event.start.format());
            eventnewstart = moment(event.start).format("DD MMMM YYYY");
            eventnewend = moment(event.end).format("DD MMMM YYYY");
            eventnewstarttime = moment(event.start).format("HH");
            eventnewendtime = moment(event.end).format("HH");

            if (!confirm("Confirm new date: " + eventnewstart + " " + eventnewstarttime + "h00 - " + eventnewend + " " + eventnewendtime + "h00")) {
                revertFunc();
            } else {
                // write new selection date
                document.getElementById("divcaldatespan").innerHTML = "<h3>DATE SELECTION: " + eventnewstart + " - " + eventnewend + "</h3>";
                eventnewstarttime = moment(event.start).format("HH:MM");
                eventnewendtime = moment(event.end).format("HH:MM");
                eventnewstart = moment(event.start).format("DD/MM/YYYY");
                eventnewend = moment(event.end).format("DD/MM/YYYY");
            }

        },

        header: {
            left: 'today prev,next',
            center: 'title',
            right: 'timelineDay,month,listWeek'
            //right: 'timelineDay,agendaWeek,month,listWeek'
        },
        defaultView: 'listWeek',
        //listDay, listWeek, listMonth, and listYear
        views: {
            listWeek: { buttonText: 'list week', noEventsMessage: "No events to display" },
            month: {
                eventLimit: 200
            }, // adjust to 6 only for agendaWeek/agendaDay
            agendaWeek: {
                eventLimit: 200
            }, // adjust to 6 only for agendaWeek/agendaDay


        },

        resourceOrder: '-type1',
        resourceAreaWidth: '40%',

        resourceColumns: [

            {
                labelText: 'Room',
                field: 'title'
            },

        ],


        resources: resources,

        events: events
        

    });
    // End  -- Defining Full Calender

    var y = 1;

    window.scroll(0, 0);
}

function closeCalendar()
{
    $('#calendar').attr("style", "display:none;");

}

function setBookingEnquiries() { 

        var bookingEnquiriesContent = "<a href='#' onclick='showCalendar(); return false; ' title='CHECK AVAILABILITY' class='btn'>CHECK AVAILABILITY</a> <br/><br/>Note: Once you&nbsp;have received confirmation that the&nbsp;room you have requested is available, you will be required to make a&nbsp;payment&nbsp;to secure&nbsp;your booking.<br><br>";
        $('#bookingEnquiries').html(bookingEnquiriesContent);

};

function showListingCalendar(resources, events, facilityTitle) {


    toggleModal();


    var incommingResources = resources;

    var incommingEvents = events;

    $('#calendar').attr("style", "");

    $('#calendarTitle').html(facilityTitle);
    $('#divcaldatespan').html(facilityTitle);


        if ($('#calendar')) {
            $('#calendar').fullCalendar('destroy'); // Destroy the calender and all resource/events.. Ready for next generation
        }
        // Define the full calender functionality , attributes
        // Start  -- Defining Full Calender
        $('#calendar').fullCalendar({

            schedulerLicenseKey: 'GPL-My-Project-Is-Open-Source',
            themeSystem: 'bootstrap4', // Select Theme system - base is standard or empty ,jquery-ui, bootstrap3
            editable: false, // enable draggable events
            nowIndicator: true,
            contentHeight: "auto",
            contentWidth: "auto",
            timezone: "Africa/Harare",
            firstDay: 1,
            navLinks: true,
            locale: "en-gb",
            businessHours: false,
            eventOverlap: false,
            slotDuration: '01:00:00',  // Set Time Slot (1 Hour default)
            //timeFormat: 'H(:mm)', // uppercase H for 24-hour clock
            allDayDefault: false,
            aspectRatio: 1.8, // 1.8 Default
            scrollTime: '08:00', // undo default 6am scrollTime
            displayEventTime: false,

            // Add your event
            selectable: false,
            selectOverlap: false,
            selectHelper: true,
            eventBorderColor: "black",

            eventClick: function (eventObj) {
                if (eventObj.url) {
                    alert(
                        'Clicked ' + eventObj.title + '.\n' +
                        'Will open ' + eventObj.url + ' in a new tab'
                    );

                    window.open(eventObj.url);

                    return false; // prevents browser from following link in current tab.
                } else {
                    //alert('Clicked ' + eventObj.title);
                    $('#calendar').fullCalendar('changeView', 'timelineDay', eventObj.start);
                }
            },

            // Monitor event drop and schedule change
            eventDrop: function (event, delta, revertFunc) {

                eventnewstart = moment(event.start).format("DD MMMM YYYY");
                eventnewend = moment(event.end).format("DD MMMM YYYY");
                eventnewstarttime = moment(event.start).format("HH");
                eventnewendtime = moment(event.end).format("HH");

                if (!confirm("Confirm new date: " + eventnewstart + " " + eventnewstarttime + "h00 - " + eventnewend + " " + eventnewendtime + "h00")) {
                    revertFunc();
                } else {
                    // write new selection date

                    document.getElementById("divcaldatespan").innerHTML = "<h3>DATE SELECTION: " + eventnewstart + " - " + eventnewend + "</h3>";
                    eventnewstarttime = moment(event.start).format("HH:MM");
                    eventnewendtime = moment(event.end).format("HH:MM");
                    eventnewstart = moment(event.start).format("DD/MM/YYYY");
                    eventnewend = moment(event.end).format("DD/MM/YYYY");

                }

            },

            // Monitor event resize and schedule change
            eventResizeStop: function (event, delta, revertFunc) {

                //alert(event.title + " was resized on " + event.start.format());
                eventnewstart = moment(event.start).format("DD MMMM YYYY");
                eventnewend = moment(event.end).format("DD MMMM YYYY");
                eventnewstarttime = moment(event.start).format("HH");
                eventnewendtime = moment(event.end).format("HH");

                if (!confirm("Confirm new date: " + eventnewstart + " " + eventnewstarttime + "h00 - " + eventnewend + " " + eventnewendtime + "h00")) {
                    revertFunc();
                } else {
                    // write new selection date
                    document.getElementById("divcaldatespan").innerHTML = "<h3>DATE SELECTION: " + eventnewstart + " - " + eventnewend + "</h3>";
                    eventnewstarttime = moment(event.start).format("HH:MM");
                    eventnewendtime = moment(event.end).format("HH:MM");
                    eventnewstart = moment(event.start).format("DD/MM/YYYY");
                    eventnewend = moment(event.end).format("DD/MM/YYYY");
                }

            },

            header: {
                left: 'today prev,next',
                center: 'title',
                right: 'timelineDay,month,listWeek'
                //right: 'timelineDay,agendaWeek,month,listWeek'
            },
            defaultView: 'listWeek',
            //listDay, listWeek, listMonth, and listYear
            views: {
                listWeek: { buttonText: 'list week', noEventsMessage: "No events to display" },
                month: {
                    eventLimit: 200
                }, // adjust to 6 only for agendaWeek/agendaDay
                agendaWeek: {
                    eventLimit: 200
                }, // adjust to 6 only for agendaWeek/agendaDay


            },

            resourceOrder: '-type1',
            resourceAreaWidth: '40%',

            resourceColumns: [

                {
                    labelText: 'Room',
                    field: 'title'
                },

            ],

           
            resources: incommingResources,

            events: events
           

        });

        var y = 1;
        


  
    var ContactDetailsFacility = "ContactDetails" + facilityTitle.replace(/\s/g, '').replace('-','');

    document.getElementById("contactDetailCalendar").innerHTML = document.getElementById(ContactDetailsFacility).innerHTML;

    resources = [];
    events = [];
    window.scroll(0, 0);



}

function checkFacilityBookingAdvancedSearch(repeaterDiv, inputHolderName) {

        var checkboxesHolder = repeaterDiv.find('input:checked');
        $('#' + inputHolderName).val("");
        var checkedItems = "";
        for (var item in checkboxesHolder) {
            var inputHolder = checkboxesHolder[item].id;

            if ($('#' + inputHolder).is(':checkbox')) {
                checkedItems += $('#' + inputHolder).val() + ',';
            }
        }

        $('#' + inputHolderName).val(checkedItems);

        //if (checkboxHolder[0].checked == true) {

        //    checkboxHolder.attr("Checked", "true");

        //} else {

        //    checkboxHolder.removeAttr("Checked");

        //}
}


    
