function setFacilityNames() {

    var startCounter = theDatatable.page() * 50;
    var endCounter = (theDatatable.page() * 50) + 50;

    for(let x=startCounter; x <  endCounter; x++) {
        if (x == facilityNamesArray.length) {
            break;
        } else {
            // facilityNames = facilityNames + facilityNamesArray[x] + "|";
            facilityNames = facilityNames +  facilityNamesArray[x] + "#" +  "" + "<img width='100%' src='" + facilityPhotosArray[x] + "'/>" + facilityNamesArray[x] +  "<br/><span id='GISPopupLocation'>" + facilityLocation[x] + "</span><br/><a href='facility?facilitytype=" + facilityType +"&facilityname=" + facilityNamesArray[x] + "' class='btn'>View Venue</a>|";

        }
    }


}



